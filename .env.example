# MQTT_HOST=127.0.0.1
# MQTT_PORT=1883
# MQTT_USERNAME=greenhouse
# MQTT_PASSWORD=replace-with-real-password
# BACKEND_MQTT_CLIENT_ID=greenhouse-backend-prod
