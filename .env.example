# ===== Backend runtime =====
STATE_STORE_BACKEND=sqlite
SQLITE_PATH=neuroagronom.db
TELEMETRY_HISTORY_BACKEND=influx

# ===== InfluxDB history =====
INFLUX_ENABLED=1
INFLUX_URL=http://127.0.0.1:8086
INFLUX_ORG=greenhouse
INFLUX_BUCKET=telemetry
INFLUX_TOKEN=
INFLUX_TIMEOUT_MS=5000

# ===== MQTT transport =====
MQTT_HOST=127.0.0.1
MQTT_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
BACKEND_MQTT_CLIENT_ID=greenhouse-backend

# ===== Zone model =====
ZONE_IDS=tray_1,tray_2,tray_3,tray_4
ZONE_TRAY_1_COOLDOWN_SEC=300
ZONE_TRAY_1_MAX_DURATION_SEC=30
ZONE_TRAY_1_MAX_RUNS_PER_HOUR=6
ZONE_TRAY_1_MAX_WATER_ML=3000
ZONE_TRAY_1_SETTLE_DELAY_MS=1500
ZONE_TRAY_1_FLOW_CONFIRM_TIMEOUT_MS=5000
ZONE_TRAY_1_MIN_FLOW_ML_PER_MIN=50
ZONE_TRAY_1_BLOCKED=0

# ===== Global safety =====
GLOBAL_MAX_SIMULTANEOUS_ZONES=1
GLOBAL_EMERGENCY_STOP=0
MASTER_PUMP_TIMEOUT_SEC=60
TOTAL_FLOW_LIMIT_PER_WINDOW_ML=5000
FLOW_WINDOW_SEC=3600
LEAK_SHUTDOWN_ENABLED=1
COMMAND_TTL_SEC=20
DEVICE_HEARTBEAT_TIMEOUT_SEC=90
BROKER_RECONNECT_LOCK_SEC=30
ANOMALY_LOOKBACK_SEC=900
MIN_PRESSURE_KPA=80
MAX_PRESSURE_KPA=400
TANK_DEPLETION_DROP_THRESHOLD=15
STALE_SENSOR_WINDOW_SEC=300
NOISY_SENSOR_DELTA_THRESHOLD=35

# ===== Llama reasoning =====
LLAMA_API_URL=http://127.0.0.1:11434/v1/chat/completions
LLAMA_MODEL=llama3.1
LLAMA_TIMEOUT_SEC=60
LLAMA_API_KEY=

# ===== OpenClaw operator layer =====
OPENCLAW_OPERATOR_ENABLED=1
OPENCLAW_OPERATOR_URL=
OPENCLAW_OPERATOR_KEY=

# ===== Operator UI =====
OPERATOR_UI_ENABLED=1
OPERATOR_UI_HOST=127.0.0.1
OPERATOR_UI_PORT=8780
