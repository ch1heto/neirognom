# =========================================================
# PRODUCTION PROFILE (Ubuntu + real hardware)
# Copy the values below into .env when deploying on site.
# =========================================================
# STATE_STORE_BACKEND=sqlite
# SQLITE_PATH=/opt/greenhouse/neuroagronom.db
# TELEMETRY_HISTORY_BACKEND=influx
